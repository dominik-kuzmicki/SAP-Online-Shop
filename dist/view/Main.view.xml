<mvc:View 
    controllerName="sap.ui.demo.controller.Main"
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns="sap.m" 
    xmlns:core="sap.ui.core">

    <VBox class="bg-gradient-to-r" >
        <VBox class="container-custom py-16 md:py-24">
            <HBox alignItems="Center" class="gap-8 items-center">
                <VBox class="space-y-6">
                    <Text text="WELCOME TO YOUR CUSTOMER PORTAL"
                        class="text-4xl md:text-5xl font-bold leading-tight text-white"/>
                    <Text text="Get 24/7 access to ordering, pricing, statuses, and your full order history."
                        class="text-lg text-primary-100"/>
                    <HBox alignItems="Center"  class="gap-4"> 
                        <Link text="Shop Now" href="#/Products/1" class="btn bg-white text-primary-800 hover:bg-gray-100"/>
                        <Link text="View My Orders"  href="#/Account/Orders" class="btn bg-transparent border border-white text-white hover:bg-white/10"/>
                    </HBox> 
                </VBox>

                <VBox class="hidden md:block">
                    <Image src="https://images.unsplash.com/photo-1544197150-b99a580bb7a8?ixlib=rb-1.2.1&amp;auto=format&amp;fit=crop&amp;w=1050&amp;q=80"
                        class="rounded-lg shadow-xl"/>
                </VBox>
            </HBox>
        </VBox>
    </VBox>


    <VBox class="container-custom">  
        <VBox class="py-16">          
            <FlexBox alignItems="Center" justifyContent="SpaceBetween" class="mb-8">
                <Text text="Product Catalog" class="text-3xl md:text-3xl font-bold" />
                <Link text="View All" href="#/Products/1" class="text-primary-600 hover:text-primary-700 flex items-center"/>
            </FlexBox>
            <FlexBox
                wrap="Wrap"
                items="{/categories}"
                class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    <CustomListItem type="Active" press="onItemPress" class="card overflow-hidden">
                        <VBox class="relative h-48">
                            <Image src="{image}" height="12rem" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"/>
                        </VBox>
                        <VBox justifyContent="End" class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end">
                            <Text class="text-white text-lg font-medium p-4" text="{name}"/>
                        </VBox>
		            </CustomListItem>
            </FlexBox>
        </VBox>
    </VBox>

    <!-- Enterprise Network Solutions -->
    <VBox class="py-16 bg-secondary-900">
        <VBox class="container-custom">
            <FlexBox alignItems="Center" class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
                <Image src="https://images.unsplash.com/photo-1573164713988-8665fc963095?ixlib=rb-1.2.1&amp;auto=format&amp;fit=crop&amp;w=800&amp;q=80" class="rounded-lg shadow-xl"/>
                <VBox class="space-y-6">
                    <Text text="Enterprise Network Solutions"
                        class="text-3xl md:text-4xl font-bold text-white"/>
                    <Text text="Complete end-to-end solutions for businesses of all sizes. From network planning to implementation and monitoring."
                        class="text-lg text-secondary-100 text-white"/>
                    <Link text="Explore Enterprise Solutions" href="#/Products/1" class="btn bg-white text-secondary-800 hover:bg-gray-100 inline-block"/>
                </VBox> 
            </FlexBox> 
        </VBox> 
    </VBox>

</mvc:View>