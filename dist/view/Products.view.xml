<mvc:View
    controllerName="sap.ui.demo.controller.Products"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <VBox class="container-custom py-8">
        <!-- Breadcrumbs -->
        <HBox class="mb-6">
            <Link text="Home" href="#/" class="text-gray-600 hover:text-primary-600 text-sm"/>
            <Text text="/" class="mx-2 text-gray-400"/>
            <Text text="Accessories" class="text-gray-500 text-sm"/>
        </HBox>

        <!-- Header -->
        <HBox class="flex justify-between items-center mb-8" lignItems="Center" justifyContent="SpaceBetween" >
            <VBox>
                <Text text="Accessories" class="text-3xl font-bold" />
                <Text text="Products found" class="text-gray-600 mt-2" />
            </VBox>

            <HBox class="flex items-center space-x-4">
                <Select selectedKey="{view>/sortOption}" change=".onSortChange" class="input min-w-[200px]">
                    <items>
                        <core:Item key="featured" text="Sort by Featured" />
                        <core:Item key="priceAsc" text="Price: Low to High" />
                        <core:Item key="priceDesc" text="Price: High to Low" />
                    </items>
                </Select>
            </HBox>
        </HBox>

        <!-- Empty State -->
        <VBox visible="{=! ${/products} === 0 }" class="text-center py-16">
            <VBox class="max-w-md mx-auto">
                <VBox class="w-24 h-24 mx-auto mb-6 bg-gray-100 rounded-full flex items-center justify-center" alignItems="Center" justifyContent="Center">
                    <core:Icon src="sap-icon://product" class="w-12 h-12 text-gray-400" />
                </VBox>
                <Text text="No products found" class="text-2xl font-semibold text-gray-900 mb-2" />
                <Text text="There are no products available in this category at the moment." class="text-gray-600 mb-8" />
                <Button text="Go Back" press=".onBack" class="btn btn-primary" />
            </VBox>
        </VBox>

        <!-- Products Grid -->
        <FlexBox id="products" items="{/products}" wrap="Wrap" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-3 gap-6">
            <VBox  class="card group overflow-hidden">
                <VBox class="relative" >
                    <Image press=".onItemPress" src="{= ${images}[0] }" class="w-full h-64 object-cover transition-transform duration-300 group-hover:scale-105" />

                    <!-- Discount badge -->
                    <VBox visible="{= ${discount} > 0 }" class="absolute top-3 left-3 bg-red-500 rounded">
                        <Text text="{discount}% OFF" class="text-white text-xs font-bold px-2 py-1"/>
                    </VBox>

                    <!-- Content -->
                    <VBox class="p-4">
                        <Text text="{name}" class="text-lg font-medium text-gray-900 mb-1 line-clamp-1" />
                        <Text text="{description}" class="text-gray-500 text-sm mb-3 line-clamp-2" />

                        <HBox class="flex items-center justify-between" alignItems="Center" justifyContent="SpaceBetween">
                            <!-- Price -->
                            <HBox class="flex items-center" alignItems="Center">
                                <Text text="{= '€' + ((100 - ${discount}) * ${price} / 100).toFixed(2)}" class="text-lg font-bold text-gray-900" />
                                <Text visible="{= ${discount} > 0 }" text="€{price}" class="ml-2 text-sm text-gray-500 line-through" />
                            </HBox>

                            <!-- Add to Cart -->
                            <Button text="Add to Cart" press=".onAddToCart" class="btn btn-primary py-1 px-3 text-xs"/>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>
        </FlexBox>
    </VBox>

</mvc:View>