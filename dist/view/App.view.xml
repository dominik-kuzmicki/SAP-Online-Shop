<mvc:View
    controllerName="sap.ui.demo.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <VBox>
        <VBox class=" bg-white sticky top-0 z-50 w-full transition-all duration-200">
            <HBox class="container-custom w-full">
                <FlexBox alignItems="Center" justifyContent="SpaceBetween" class="h-16" width="100%"> 
                    <HBox id="mainBox">
                        <Text text="TechConnect" class="hw-link-reset text-primary-600 font-bold text-2xl cursor-pointer"/> 
                    </HBox>
                    <FlexBox alignItems="Center" justifyContent="SpaceBetween" class="hidden md:flex space-x-8"> 
                        <Link href="#/" class="text-sm font-medium hover-text-primary-600" text="Home" />
                        <Link href="#/Products/1" class="text-sm font-medium hover-text-primary-600" text="Product Catalog"/>
                    </FlexBox>
                    <SearchField class="search hidden md:flex items-center flex-1 max-w-md mx-4" search="onSearch" placeholder="Search products..." width="100%"/>
                    <FlexBox alignItems="Center" justifyContent="SpaceBetween" class="space-x-4" width="">
                        <HBox class="relative p-2 text-gray-600 hover:text-primary-600" renderType="Bare">
                            <core:Icon size="1.15rem" src="sap-icon://cart" press="onCart"/>
                            <Text text="{path: 'cart>/quantity'}" visible="{= ${cart>/quantity} > 0 }"
                                class="cartBadge absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-primary-600 text-xs text-white"/>
                        </HBox>
                        <core:Icon class="p-2 text-gray-600" size="1.15rem" src="sap-icon://person-placeholder" press="onAccount"/>
                    </FlexBox>
                </FlexBox>
            </HBox>
        </VBox>
        
        <App id="app"/>
        
    </VBox>
</mvc:View>