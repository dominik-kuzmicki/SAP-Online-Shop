<mvc:View
    controllerName="sap.ui.demo.controller.Cart"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">

    <!-- Busy -->
    <FlexBox
        justifyContent="Center"
        alignItems="Center"
        height="100%"
        visible="{uiModel>/busy}">
        <BusyIndicator size="3rem"/>
    </FlexBox>

    <!-- Ordered -->
    <VBox visible="{uiModel>/isOrdered}" class="container-custom py-16">
        <VBox class="text-center">
            <Text text="Thank you for your order!" class="text-2xl font-bold mb-4" />
            <Text text="Your order {order>/id} has been placed successfully." class="text-gray-600 mb-8" />
            <Text text="You can track your order status in your account dashboard." class="text-gray-600" />
            <Text text="If you have any questions, our support team is here to help." class="text-gray-600 mb-8" />
            <Button text="View Order History" press=".onOrders" class="btn btn-primary" />
        </VBox>
    </VBox>

    <VBox visible="{= !${uiModel>/isOrdered} ? !(${uiModel>/busy} ? true : false) : false }">
    <!-- Empty Cart State -->
    <VBox visible="{= ${cart>/quantity} === 0}" class="container-custom py-16">
        <VBox class="text-center">
            <VBox class="h-16 w-16 mx-auto text-gray-400 mb-4 flex items-center justify-center" alignItems="Center" justifyContent="Center">
                <core:Icon src="sap-icon://cart" class="h-16 w-16 text-gray-400" />
            </VBox>
            <Text text="Your cart is empty" class="text-2xl font-bold mb-4" />
            <Text text="Looks like you haven't added any products to your cart yet." class="text-gray-600 mb-8" />
            <Button text="Continue Shopping" press=".onContinueShopping" class="btn btn-primary" />
        </VBox>
    </VBox>

    <VBox visible="{= ${cart>/quantity} > 0}" class="container-custom py-8">
        <Text class="text-3xl font-bold mb-8" text="Shopping Cart"/>

        <VBox class="grid grid-cols-3 gap-8">
            <VBox class="col-span-2">
                <VBox class="bg-white rounded-lg shadow-sm overflow-hidden">
                    <HBox class="grid grid-cols-12 gap-4 p-4 bg-gray-50 border-b">
                      <VBox class="col-span-6">
                        <Text class="font-medium" text="Product"/>
                      </VBox>
                      <VBox class="col-span-2 text-center">
                        <Text class="font-medium" text="Price"/>
                      </VBox>
                      <VBox class="col-span-2 text-center">
                        <Text class="font-medium" text="Quantity"/>
                      </VBox>
                      <VBox class="col-span-2 text-right">
                        <Text class="font-medium" text="Total"/>
                      </VBox>
                    </HBox >

                    <VBox id="cart" items="{cart>/items}" class="divide-y">
                        <HBox key="{cart>ID}" class="p-4 grid grid-cols-12 gap-4 items-center">
                            <HBox class="col-span-6 flex items-center">
                                <HBox class="w-20 h-20 flex-shrink-0 overflow-hidden rounded-md">
                                    <Image src="{cart>image}" alt="{cart>name}" class="w-full h-full object-cover" press="onItemPress"/>
                                </HBox>
                                <VBox class="ml-4 flex-1 mt-4">
                                    <Link text="{cart>name}" href="{= '/index.html#/Product/' + ${cart>ID}}" class="text-sm font-medium text-gray-900"/>
                                    <Text class="mt-1 text-sm text-gray-500" text="Accessories"/>
                                </VBox>
                            </HBox> 
 
                            <VBox class="col-span-2 mt-4 mt-0 text-center">
                                <Text class="text-sm font-medium text-gray-900" text="{= '€' + ((100 - ${cart>discount}) * ${cart>price} / 100).toFixed(2)}"/>                      
                                <Text visible="{= ${cart>discount} > 0 }" class="block text-xs text-gray-500 line-through" text="€{cart>price}"/>
                            </VBox>

                            <HBox class="col-span-2 mt-4 sm:mt-0 flex justify-center">
                                <StepInput value="{cart>quantity}" max="{cart>stock}" min="1" change=".onChangeQuantity" width="2.5rem" class="mt-4"/>
                            </HBox>

                            <HBox justifyContent="End" alignItems="Center" class="col-span-2 mt-4 sm:mt-0 flex items-center justify-between sm:justify-end">
                                <Text text="{= '€' + (((100 - ${cart>discount}) * ${cart>price} / 100).toFixed(2) * ${cart>quantity}).toFixed(2) }" class="text-sm font-medium text-gray-900 sm:text-right"/>
                                <core:Icon class="ml-4 text-gray-400 hover:text-red-500 sm:block" src="sap-icon://delete" press=".onRemoveProduct"/>
                            </HBox>
                        </HBox>
                    </VBox>
                    
                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="p-4 border-t border-gray-200 flex justify-between">
                        <Link text="Clear Cart" press=".onClearCart" class="text-sm text-red-600 hover:text-red-500" />
                        <Link text="Continue Shopping" press=".onContinueShopping" class="text-sm text-primary-600 hover:text-primary-500" />
                    </HBox>
                </VBox>
            </VBox>

            <!-- Order Summary -->
            <VBox class="col-span-1">
                <VBox class="bg-white rounded-lg shadow-sm p-6">
                    <Text text="Order Summary" class="mb-4 text-lg font-medium" />
                    <VBox class="space-y-2">
                        <HBox justifyContent="SpaceBetween">
                            <Text text="Subtotal" class="text-base text-gray-600" />
                            <Text text="{path: 'cart>/subtotal', formatter: '.formatCurrency'}" class="font-medium" />
                        </HBox>
                        <HBox visible="{= ${cart>/discount} > 0 }" justifyContent="SpaceBetween">
                            <Text text="Discount" class="text-base text-green-600" />
                            <Text text="-{path: 'cart>/discount', formatter: '.formatCurrency'}" class="font-medium text-green-600" />
                        </HBox>
                        <HBox justifyContent="SpaceBetween" class="border-t pt-4">
                            <Text text="Total" class="font-medium" />
                            <Text text="{path: 'cart>/total', formatter: '.formatCurrency'}" class="font-bold text-lg" />
                        </HBox>
                    </VBox>

                    <!-- Promo code -->
                    <VBox class="mt-6">
                        <Text text="Promo Code" labelFor="promoInput" class="block text-sm font-medium text-gray-700 mb-1" />
                        <HBox class="flex space-x-2">
                            <Input id="promoInput" value="{cart>/promoInput}" enabled="{= !${cart>/promoCode} }" placeholder="Enter code" class="input flex-1" />
                            <Button text="{= ${cart>/promoCode} ? 'Remove' : 'Apply' }" type="Transparent" press="{= ${cart>/promoCode} ? '.onRemovePromoCode' : '.onApplyPromoCode' }" class="btn btn-outline" />
                        </HBox>
                        <!-- <Text visible="{cart>/promoError}" text="{cart>/promoError}" class="mt-1 text-sm text-red-600" /> -->
                        <!-- <Text visible="{cart>/promoCode}" text="PROMO" class="mt-1 text-sm text-green-600" /> -->
                    </VBox>

                    <VBox class="mt-6">
                        <Text text="Order Comment" class="block text-sm font-medium text-gray-700 mb-1" />
                        <TextArea value="{cart>/comment}" rows="3" maxLength="500"
                            placeholder="Add any special instructions or comments for your order..."
                            class="input w-full resize-none"/>
                    </VBox>

                    <Button text="Submit Order" press=".onSubmitOrder" class="btn btn-primary w-full mt-6" icon="sap-icon://arrow-right" iconFirst="false" />
                </VBox>
            </VBox>
        </VBox>
    </VBox>
    </VBox>
</mvc:View>

