<mvc:View
    controllerName="sap.ui.demo.controller.Subcategories"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <VBox class="mainPage">
        <Breadcrumbs id="breadcrumbs2" class="sapUiTinyMarginTop" currentLocationText="Accesories">
                <Link text="Main" press="onBreadcrumbPress" />
        </Breadcrumbs>

        <Title text="Product categories" class="sapUiMediumMarginTop productTitle" />
        <Text text="The Company portfolio includes all major categories of broadband products necessary to get the job done right." 
            class="sapUiSmallMarginTop sapUiMediumMarginBottom productSubtitle"/>

        <FlexBox
            width="100%"
            wrap="Wrap"
            alignItems="Start"
            justifyContent="SpaceBetween"
            items="{/subcategories}">
			<CustomListItem class="productCard" type="Active" press="onItemPress">
                    <Image src="{image}" width="100%" height="150px" class="productImage"/>
                    <Text text="{name}" class="productName" />
		    </CustomListItem>
        </FlexBox>
    </VBox>
</mvc:View>