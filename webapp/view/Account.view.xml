<mvc:View 	
    controllerName="sap.ui.demo.controller.Account"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <VBox class="container-custom py-8">
        <VBox class="grid grid-cols-1 grid-cols-4 gap-8">    
            
            <VBox class="lg:col-span-1">
                <!-- Sidebar -->
                <VBox class="bg-white rounded-lg shadow-sm p-6">
                    <HBox class="flex items-center mb-6" alignItems="Center">
                      <VBox class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center" alignItems="Center">
                        <core:Icon src="sap-icon://person-placeholder" class="h-6 w-6 text-primary-600"/>
                      </VBox>

                      <VBox class="ml-3">
                        <Text text="{userModel>/name} {userModel>/lastName}" class="text-lg font-medium"/>
                        <Text text="{userModel>/email}" class="text-sm text-gray-500"/>
                      </VBox>
                    </HBox>

                    <VBox class="space-y-2">
                        <Button text="Profile" icon="sap-icon://person-placeholder" iconFirst="false" press=".onTabProfile"
                            class="w-full flex items-center px-3 py-2 text-left rounded-md transition-colors"
                            type="{= ${uiModel>/activeTab} === 'Profile' ? 'Emphasized' : 'Transparent'}"/>

                        <Button text="Orders" icon="sap-icon://shipping-status" iconFirst="false" press=".onTabOrders"
                            class="w-full flex items-center px-3 py-2 text-left rounded-md transition-colors"
                            type="{= ${uiModel>/activeTab} === 'Orders' ? 'Emphasized' : 'Transparent'}"/>

                        <Button text="Sign Out" press=".onLogout" 
                            class="w-full flex items-center px-3 py-2 text-left rounded-md text-red-600 hover:bg-red-50 transition-colors"/>
                    </VBox>
                </VBox>
            </VBox>

            <VBox class="lg:col-span-3">    
                <!-- PROFILE -->
                <VBox visible="{= ${uiModel>/activeTab} === 'Profile' }" class="bg-white rounded-lg shadow-sm p-6">
                    <Text text="Profile Information" class="text-2xl font-bold mb-6"/>
                    <HBox class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <VBox class="md:col-span-2">
                            <Text text="Full Name" class="block text-sm font-medium text-gray-700 mb-1"/>
                            <Text text="{userModel>/name}" class="text-gray-900"/>
                        </VBox>
                        <VBox>
                            <Text text="Email Address" class="block text-sm font-medium text-gray-700 mb-1"/>
                            <Text text="{userModel>/email}" class="text-gray-900"/>
                        </VBox>
                        <VBox>
                            <Text text="Phone Number" class="block text-sm font-medium text-gray-700 mb-1"/>
                            <Text text="{userModel>/phone}" class="text-gray-900"/>
                        </VBox>
                    </HBox>
                    <VBox class="mt-8 pt-8 border-t">
                        <Text text="Your Sales Contact" class="text-lg font-medium mb-6"/>
                        <HBox class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <VBox class="md:col-span-2">
                                <Text text="Sales Representative" class="block text-sm font-medium text-gray-700 mb-1"/>
                                <Text text="{userModel>/managerName}" class="text-gray-900"/>
                            </VBox>
                            <VBox>
                                <Text text="Email Address" class="block text-sm font-medium text-gray-700 mb-1"/>
                                <Text text="{userModel>/managerEmail}" class="text-gray-900"/>
                            </VBox>
                            <VBox>
                                <Text text="Phone Number" class="block text-sm font-medium text-gray-700 mb-1"/>
                                <Text text="{userModel>/managerPhone}" class="text-gray-900"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- ORDERS -->
                <VBox visible="{= ${uiModel>/activeTab} === 'Orders' }" class="bg-white rounded-lg shadow-sm p-6">
                    <Text text="Order History" class="text-2xl font-bold mb-6"/>
                    <!-- Busy -->
                    <FlexBox
                        justifyContent="Center"
                        alignItems="Center"
                        height="100%"
                        visible="{/busy}">
                        <BusyIndicator size="3rem"/>
                    </FlexBox>

                    <VBox items="{/orders}" visible="{= !${/busy} }" class="gap-4">
                        <VBox class="border border-gray-200 rounded-lg p-4">
                            <HBox justifyContent="SpaceBetween" class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4">
                                <VBox>
                                    <Text text="Order #{id}" class="text-lg font-medium"/>
                                    <Text text="Placed on {createdat}" class="text-sm text-gray-6000"/>
                                </VBox>
                                <HBox class="flex items-center space-x-4 mt-2 sm:mt-0" alignItems="Center">
                                    <ObjectStatus text="{status}" state="{ path: 'status', formatter: '.formatStatusState' }" class="inline-flex px-3 py-1 text-sm font-medium rounded-full"/>
                                    <Button text="View Details" press=".onItemPress" class="btn btn-outline btn-sm"/>
                            </HBox>
                            </HBox>
                            <HBox class="grid grid-cols-3 gap-4 text-sm">
                                <VBox>
                                    <Text text="Total Amount:" class="text-gray-600"/>
                                    <Text text="€{total}" class="font-medium"/>
                                </VBox>
                                <VBox>
                                    <Text text="Items:" class="text-gray-600"/>
                                    <Text text="{= ${items}.length + ' items' }" class="font-medium"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>
            </VBox>
        
        </VBox>

    </VBox>
</mvc:View>